# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Base URL of the deploy (QR + Slack links)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Ramp — mock by default; set "false" only when sandbox is wired
NEXT_PUBLIC_RAMP_MOCK=true
NEXT_PUBLIC_RAMP_ORG_ID=RAMP-DEMO-2026
# Ramp real sandbox (server-only; used only when NEXT_PUBLIC_RAMP_MOCK=false).
# Create a Client Credentials grant under Settings > Developer in the Ramp dashboard.
RAMP_API_BASE=https://demo-api.ramp.com
RAMP_CLIENT_ID=
RAMP_CLIENT_SECRET=
RAMP_SCOPES=limits:write spend_programs:read users:read transactions:read
# Account-specific IDs from your Ramp sandbox (which pool funds the bonus, who receives it):
RAMP_SPEND_PROGRAM_ID=
RAMP_MEMBER_USER_ID=

# Slack — mock by default; set "false" only when the app is installed
SLACK_MOCK=true
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
