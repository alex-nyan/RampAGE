# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Base URL of the deploy (QR + Slack links)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Ramp — mock by default; set "false" only when sandbox is wired
NEXT_PUBLIC_RAMP_MOCK=true

# Slack — mock by default; set "false" only when the app is installed
SLACK_MOCK=true
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
